<!DOCTYPE html>
<html lang="en" style="height:100%;overflow:hidden;">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <link rel="icon" href="{{ site.baseUrl }}static/images/logo.ico">
    <link rel="stylesheet" href="{{ site.baseUrl }}static/css/style.css">
</head>

<body class='landing'>
</body>

<script>
// script.js
document.addEventListener('DOMContentLoaded', function() {
    // 1. Define an array of image URLs
    const images = [
        "{{ site.baseUrl }}static/images/1.jpg",
        "{{ site.baseUrl }}static/images/2.jpg",
        "{{ site.baseUrl }}static/images/3.jpg",
        "{{ site.baseUrl }}static/images/4.jpg",
        "{{ site.baseUrl }}static/images/5.jpg",
        "{{ site.baseUrl }}static/images/6.jpg",
    ];

    const randomIndex = Math.floor(Math.random() * images.length);
    const selectedImage = images[randomIndex];

    document.body.style.backgroundImage = `url('${selectedImage}')`;

});

document.addEventListener('click', function(event) {
    window.location.href = "{{ site.baseUrl }}home";
});

</script>